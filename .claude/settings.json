{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "Setup": [
      {
        "matcher": "init",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/with-nix.sh bash -c 'cd \"$CLAUDE_PROJECT_DIR\" && bun install && bun run build'",
            "timeout": 120
          }
        ]
      },
      {
        "matcher": "maintenance",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/with-nix.sh bash -c 'cd \"$CLAUDE_PROJECT_DIR\" && bun install && bun run build && bun run verify'",
            "timeout": 120
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/with-nix.sh bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/stop-doc-check.ts",
            "timeout": 60
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/with-nix.sh bash -c 'cd \"$CLAUDE_PROJECT_DIR\" && bun run verify'",
            "timeout": 60
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [],
    "deny": [],
    "ask": []
  }
}
