{
  "name": "claude-code-plugins",
  "version": "1.0.0",
  "description": "A local plugin marketplace for Claude Code",
  "private": true,
  "keywords": [
    "pi-package"
  ],
  "pi": {
    "skills": [
      "./plugins/bdfl/skills",
      "./plugins/dev/skills",
      "./plugins/doc-writer/skills",
      "./plugins/langs/skills"
    ],
    "prompts": [
      "./plugins/dev/commands",
      "./plugins/dev/agents"
    ]
  },
  "type": "module",
  "workspaces": [
    "lib",
    "plugins/*",
    ".claude/hooks"
  ],
  "scripts": {
    "build": "bun run typecheck",
    "check": "biome check --fix --unsafe .",
    "lint": "biome lint --fix --unsafe .",
    "format": "biome format --fix .",
    "verify": "bun run lint && bun run typecheck",
    "typecheck": "tsc --build"
  },
  "dependencies": {
    "fast-xml-parser": "^5.3.1"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.37",
    "@biomejs/biome": "^2.4.7",
    "@types/bun": "^1.3.2",
    "@types/node": "^24.10.0",
    "typescript": "^5.7.2"
  },
  "author": "codethread",
  "license": "MIT"
}
